}

/* Apply "..." at 100% width */
.truncate-width { 
		width: 100%; 
    white-space: nowrap; 
    overflow: hidden; 
    text-overflow: ellipsis; 
}
/* Removes native scrollbar */
.no-scrollbar {
    -ms-overflow-style: none;
    overflow: -moz-scrollbars-none; 
}

.no-scrollbar::-webkit-scrollbar {
    display: none;
}

.news_posts-item:hover .news-header_child_content-wrapper .text-big-regular {
  color: var(--color--links);
} 

  /* Inline code styling in blog rich text */
  .text-rich-text :not(pre) > code {
    font-family: "JetBrains Mono", "SFMono-Regular", Menlo, monospace;
    font-size: 0.86em;
    line-height: 1.05;
    padding: 0.1em 0.38em;
    /* border-radius: 0.38em; */
    vertical-align: baseline;

    /* fallback */
    color: #9f1239;
    background: #eef0f3;
    border: 1px solid #d5d9df;

    /* theme-aware (light/dark) */
    color: var(--color--text-main);
    background: color-mix(in srgb, var(--color--text-main) 10%, var(--color--background));
    border: 1px solid color-mix(in srgb, var(--color--text-main) 20%, var(--color--background));
  }
  
    /* Light mode: lighter fill */
  .text-rich-text :not(pre) > code {
    background: rgba(17, 24, 39, 0.06);
    border-color: rgba(17, 24, 39, 0.14);
  }

  /* Dark mode (your toggle sets aria-pressed="true"): darker fill */
  html:has([tr-color-toggle][aria-pressed="true"]) .text-rich-text :not(pre) > code {
    background: rgba(0, 0, 0, 0.34);
    border-color: rgba(255, 255, 255, 0.14);
  }
  

// Script to change dropdown toggle text color to #202020 when open in light mode
// and normal nav links text color to #202020 on hover in light mode

function isLightMode() {
  const colorToggle = document.querySelector('[tr-color-toggle]');
  return colorToggle && colorToggle.getAttribute('aria-pressed') === 'false';
}

function updateDropdownTextColor() {
  // Get all dropdown components
  const dropdowns = document.querySelectorAll('.dropdown1_component');
  const lightMode = isLightMode();
  
  dropdowns.forEach(dropdown => {
    const toggle = dropdown.querySelector('.dropdown1_toggle');
    const navText = toggle ? toggle.querySelector('.nav-text') : null;
    const chevron = toggle ? toggle.querySelector('.dropdown-chevron') : null;
    
    if (toggle && navText) {
      // Check if dropdown is open (has w--open class)
      const isOpen = toggle.classList.contains('w--open');
      
      // Apply color #202020 only if light mode AND dropdown is open
      if (lightMode && isOpen) {
        navText.style.color = '#202020';
        if (chevron) {
          chevron.style.color = '#202020';
        }
      } else {
        // Remove inline style to let CSS handle it
        navText.style.color = '';
        if (chevron) {
          chevron.style.color = '';
        }
      }
    }
  });
}

function setupNavLinkHover() {
  // Get all normal nav links
  const navLinks = document.querySelectorAll('.nav_link.is-normal-link');
  
  navLinks.forEach(link => {
    const textDiv = link.querySelector('div');
    
    if (textDiv) {
      // Store original color on first setup
      if (!textDiv.dataset.originalColor) {
        textDiv.dataset.originalColor = window.getComputedStyle(textDiv).color;
      }
      
      // Mouse enter - change to #202020 if light mode
      link.addEventListener('mouseenter', function() {
        if (isLightMode()) {
          textDiv.style.color = '#202020';
        }
      });
      
      // Mouse leave - restore original color
      link.addEventListener('mouseleave', function() {
        textDiv.style.color = '';
      });
    }
  });
}

// Run on page load
updateDropdownTextColor();
setupNavLinkHover();

// Observe changes to dropdown states and color mode
const observer = new MutationObserver(() => {
  updateDropdownTextColor();
});

// Observe the entire document for class changes
observer.observe(document.body, {
  attributes: true,
  attributeFilter: ['class', 'aria-pressed', 'aria-expanded'],
  subtree: true
});

// Also listen for click events as a backup
document.addEventListener('click', () => {
  setTimeout(updateDropdownTextColor, 50);
});
</script></div><div class="nav_menu-buttons_component"><div class="nav_menu-buttons_wrapper"><a data-no-transition="" href="https://app.letta.com" target="_blank" class="button w-button">Letta Developer Platform</a><div class="spacer-small"></div><p class="nav_description">Use the Letta API to build agents that can actually remember and learn about your users over time. Open source, production ready, and fully model-agnostic.</p></div><div class="nav_menu-buttons_wrapper"><a data-no-transition="" href="https://docs.letta.com/letta-code" target="_blank" class="button w-button">Letta Code</a><div class="spacer-small"></div><p class="nav_description">Letta Code is a memory-first coding harness, built on top of the Letta API. Instead of working in independent sessions, you work with a persisted agent that learns over time and is portable across models.</p><div class="spacer-xxsmall"></div></div><div tr-color-toggle="" class="nav_menu-switcher_wrapper"><div class="nav_menu-switcher"><div id="mode_switch-bg_nav" class="mode_switch-bg is-nav"></div><div class="mode_switch-nav is-light"><div>Light</div></div><div class="mode_switch-nav is-dark"><div>Dark</div></div></div></div></div></nav></div><div class="nav-mobile-button_wrapper"><a data-no-transition="" href="https://github.com/cpacker/MemGPT" target="_blank" class="nav-github_wrapper is-mobile w-inline-block"><div class="icon-embed-github w-embed"><svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 20 20" fill="none" preserveAspectRatio="xMidYMid meet" aria-hidden="true" role="img">

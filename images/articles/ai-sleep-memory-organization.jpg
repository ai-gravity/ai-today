<!--Text Glitch effect on hover! -->
<script>
function startGlitch(element, callback) {
    const glitchChars = "!<>-_\\/[]{}—=+*^?#________";
    const originalText = element.textContent;
    let glitchInterval;
    let glitchTimeout;

    function getRandomDuration(min, max) {
        return Math.random() * (max - min) + min;
    }

    const glitchDuration = getRandomDuration(0.6, 1.5); // Adjusted for visibility

    // Ensure no leftover intervals
    clearInterval(glitchInterval);

    glitchInterval = setInterval(() => {
        let newText = '';
        for (let i = 0; i < originalText.length; i++) {
            newText += Math.random() < 0.2 ? glitchChars[Math.floor(Math.random() * glitchChars.length)] : originalText[i];
        }
        element.textContent = newText;

        gsap.to(element, {
            skewX: Math.random() * 15 - 7, // Reduced skew for realism
            opacity: Math.random() < 0.8 ? 0.85 : 1,
            duration: 0.03, // Increased for smoother effect
            ease: "power2.out",
        });

    }, 50); // Adjusted to avoid too many calls

    glitchTimeout = setTimeout(() => {
        clearInterval(glitchInterval);
        element.textContent = originalText;

        gsap.to(element, {
            skewX: 0,
            opacity: 1,
            duration: 0.15,
            onComplete: callback 
        });

    }, glitchDuration * 1000);
}

const divIds = ['#footer-links-1','#footer-links-2', '#footer-links-3', '#footer-links-4'];
let currentDivIndex = 0;
const usedLinks = {
    '#footer-links-1': new Set(),
    '#footer-links-2': new Set(),
    '#footer-links-3': new Set(),
    '#footer-links-4': new Set(),
};

function getNextRandomDivIndex(currentIndex) {
    let nextIndex;
    do {
        nextIndex = Math.floor(Math.random() * divIds.length);
    } while (nextIndex === currentIndex);
    return nextIndex;
}

function sequentialGlitch() {
    const currentDivId = divIds[currentDivIndex];
    const links = document.querySelectorAll(`${currentDivId} .footer-link`);

    if (!links.length) return; // Prevent errors if elements are missing

    if (usedLinks[currentDivId].size === links.length) {
        usedLinks[currentDivId].clear();
    }

    const availableLinks = Array.from(links).filter((_, index) => !usedLinks[currentDivId].has(index));

    if (availableLinks.length > 0) {
        const randomIndex = Math.floor(Math.random() * availableLinks.length);
        const randomLink = availableLinks[randomIndex];
        const originalLinkIndex = Array.from(links).indexOf(randomLink);

        usedLinks[currentDivId].add(originalLinkIndex);

        startGlitch(randomLink, () => {
            currentDivIndex = getNextRandomDivIndex(currentDivIndex);

            setTimeout(sequentialGlitch, 800); // Adjusted for more natural delay
        });
    } else {
        currentDivIndex = getNextRandomDivIndex(currentDivIndex);
        setTimeout(sequentialGlitch, 200); // Small delay to avoid rapid recursion
    }
}

// Delay the start slightly to prevent immediate recursion
setTimeout(sequentialGlitch, 1000);
</script>




<script>
// MARQUEE POWER-UP
window.addEventListener("DOMContentLoaded", (event) => {
  // attribute value checker
  function attr(defaultVal, attrVal) {
    const defaultValType = typeof defaultVal;
    if (typeof attrVal !== "string" || attrVal.trim() === "") return defaultVal;
    if (attrVal === "true" && defaultValType === "boolean") return true;
    if (attrVal === "false" && defaultValType === "boolean") return false;
    if (isNaN(attrVal) && defaultValType === "string") return attrVal;
    if (!isNaN(attrVal) && defaultValType === "number") return +attrVal;
    return defaultVal;
  }
  // marquee component
  $("[tr-marquee-element='component']").each(function (index) {
    let componentEl = $(this),
      panelEl = componentEl.find("[tr-marquee-element='panel']"),
      triggerHoverEl = componentEl.find("[tr-marquee-element='triggerhover']"),
      triggerClickEl = componentEl.find("[tr-marquee-element='triggerclick']");
    let speedSetting = attr(100, componentEl.attr("tr-marquee-speed")),
      verticalSetting = attr(false, componentEl.attr("tr-marquee-vertical")),
      reverseSetting = attr(false, componentEl.attr("tr-marquee-reverse")),
      scrollDirectionSetting = attr(false, componentEl.attr("tr-marquee-scrolldirection")),
      scrollScrubSetting = attr(false, componentEl.attr("tr-marquee-scrollscrub")),
      moveDistanceSetting = -100,
      timeScaleSetting = 1,
      pausedStateSetting = false;
    if (reverseSetting) moveDistanceSetting = 100;
    let marqueeTimeline = gsap.timeline({ repeat: -1, onReverseComplete: () => marqueeTimeline.progress(1) });
    if (verticalSetting) {
      speedSetting = panelEl.first().height() / speedSetting;
      marqueeTimeline.fromTo(panelEl, { yPercent: 0 }, { yPercent: moveDistanceSetting, ease: "none", duration: speedSetting });
    } else {
      speedSetting = panelEl.first().width() / speedSetting;
      marqueeTimeline.fromTo(panelEl, { xPercent: 0 }, { xPercent: moveDistanceSetting, ease: "none", duration: speedSetting });
    }
    let scrubObject = { value: 1 };
    ScrollTrigger.create({
      trigger: "body",
      start: "top top",
      end: "bottom bottom",
      onUpdate: (self) => {
        if (!pausedStateSetting) {
          if (scrollDirectionSetting && timeScaleSetting !== self.direction) {
            timeScaleSetting = self.direction;
            marqueeTimeline.timeScale(self.direction);
          }
          if (scrollScrubSetting) {
            let v = self.getVelocity() * 0.006;
            v = gsap.utils.clamp(-60, 60, v);
            let scrubTimeline = gsap.timeline({ onUpdate: () => marqueeTimeline.timeScale(scrubObject.value) });
            scrubTimeline.fromTo(scrubObject, { value: v }, { value: timeScaleSetting, duration: 0.5 });
          }
        }
      }
    });
    function pauseMarquee(isPausing) {
      pausedStateSetting = isPausing;
      let pauseObject = { value: 1 };
      let pauseTimeline = gsap.timeline({ onUpdate: () => marqueeTimeline.timeScale(pauseObject.value) });
      if (isPausing) {
        pauseTimeline.fromTo(pauseObject, { value: timeScaleSetting }, { value: 0, duration: 0.5 });
        triggerClickEl.addClass("is-paused");
      } else {
        pauseTimeline.fromTo(pauseObject, { value: 0 }, { value: timeScaleSetting, duration: 0.5 });
        triggerClickEl.removeClass("is-paused");
      }
    }
    if (window.matchMedia("(pointer: fine)").matches) {
      triggerHoverEl.on("mouseenter", () => pauseMarquee(true));
      triggerHoverEl.on("mouseleave", () => pauseMarquee(false));
    }
    triggerClickEl.on("click", function () {
      !$(this).hasClass("is-paused") ? pauseMarquee(true) : pauseMarquee(false);
    });
  });
});
</script>

<script>
document.querySelectorAll('[data-gsap="hover.1"]').forEach((element) => {
    const glitchChars = "!<>-_\\/[]{}—=+*^?#________";
    let originalText = element.textContent;
    let glitchInterval;
    let glitchTimeout;

    function getRandomDuration(min, max) {
        return Math.random() * (max - min) + min;
    }

    function startGlitch() {
        if (!element.dataset.hovering) return; 

        const glitchDuration = getRandomDuration(0.5, 1.25); 
        const glitchCycle = glitchDuration + 1.25; 

        glitchInterval = setInterval(() => {
            let newText = '';
            for (let i = 0; i < originalText.length; i++) {
               
                newText += Math.random() < 0.1 ? glitchChars[Math.floor(Math.random() * glitchChars.length)] : originalText[i];
            }
            element.textContent = newText;

           
            gsap.to(element, {
                skewX: Math.random() * 20 - 10, 
                opacity: Math.random() < 0.8 ? 0.8 : 1, 
                duration: 0.003, 
                ease: "power2.out",
            });
        }, 40); 
       
        glitchTimeout = setTimeout(() => {
            clearInterval(glitchInterval);
            element.textContent = originalText;

           
            gsap.to(element, {
                skewX: 0,
                opacity: 1, 
                textShadow: "none",
                duration: 0.1,
            });

  
            if (element.dataset.hovering) {
                glitchTimeout = setTimeout(startGlitch, glitchCycle * 1000);
            }
        }, glitchDuration * 1000);
    }

    function handleMouseEnter() {
        element.dataset.hovering = true;
        startGlitch();
    }

    function handleMouseLeave() {
        element.dataset.hovering = false;
        clearInterval(glitchInterval);
        clearTimeout(glitchTimeout); 
        element.textContent = originalText; 
        gsap.to(element, {
            skewX: 0,
            opacity: 1, 
            textShadow: "none",
            duration: 0.1,
        });
    }

    element.addEventListener('mouseenter', handleMouseEnter);
    element.addEventListener('mouseleave', handleMouseLeave);
});

</script>


<script>
function colorModeToggle() {
  const htmlElement = document.documentElement;
  const computed = getComputedStyle(htmlElement);
  let toggleEl;
  const scriptTag = document.querySelector("[tr-color-vars]");
  if (!scriptTag) {
    console.warn("Script tag with tr-color-vars attribute not found");
    return;
  }
  const colorModeDuration = parseFloat(scriptTag.getAttribute("duration")) || 1.0;
  const colorModeEase = scriptTag.getAttribute("ease") || "ease";
  const cssVariables = scriptTag.getAttribute("tr-color-vars");
  if (!cssVariables) {
    console.warn("Value of tr-color-vars attribute not found");
    return;
  }
  const lightColors = {};
  const darkColors = {};
  cssVariables.split(",").forEach(function (item) {
    const lightValue = computed.getPropertyValue(`--color--${item}`);
    const darkValue = computed.getPropertyValue(`--dark--${item}`);
    if (lightValue) {
      lightColors[`--color--${item}`] = lightValue;
      darkColors[`--color--${item}`] = darkValue || lightValue;
    }
  });
  if (!Object.keys(lightColors).length) {
    console.warn("No variables found matching tr-color-vars attribute value");
    return;
  }

  function swapImages(isDark) {
    const imageElements = document.querySelectorAll('img[data-light-src][data-dark-src]');
    imageElements.forEach(img => {
      const lightSrc = img.getAttribute('data-light-src');
      const darkSrc = img.getAttribute('data-dark-src');
      img.src = isDark ? darkSrc : lightSrc;
    });
  }

  // New function to swap background images
  function swapBackgroundImages(isDark) {
    const bgElements = document.querySelectorAll('[data-light-bg][data-dark-bg]');
    bgElements.forEach(el => {
      const lightBg = el.getAttribute('data-light-bg');
      const darkBg = el.getAttribute('data-dark-bg');
      el.style.backgroundImage = isDark ? `url('${darkBg}')` : `url('${lightBg}')`;
    });
  }

  function setCSLogos(isDark) {
  	const logoElements = document.querySelectorAll("[data-cs-logo]");
  	logoElements.forEach(logo => {
    if (isDark) {
      logo.classList.add("is-invert-filter");
    } else {
      logo.classList.remove("is-invert-filter");
    }
  	});
  }

  
  function setColors(isDark, animate) {
    const colorObject = isDark ? darkColors : lightColors;
    const noTransitionElements = document.querySelectorAll('[data-no-transition]');
    
    noTransitionElements.forEach(el => {
      el.style.transition = 'none';
    });

    if (typeof gsap !== "undefined" && animate) {
      gsap.to(htmlElement, {
        ...colorObject,
        duration: colorModeDuration,
        ease: colorModeEase,
        onComplete: () => {
          noTransitionElements.forEach(el => {
            el.style.transition = '';
          });
        }
      });
    } else {
      Object.entries(colorObject).forEach(([key, value]) => {
        htmlElement.style.setProperty(key, value);
      });
      setTimeout(() => {
        noTransitionElements.forEach(el => {
          el.style.transition = '';
        });
      }, 0);
    }

    // Handle mode switch background
    const modeSwitchNav = document.getElementById('mode_switch-bg_nav');
    const modeSwitchBg = document.getElementById('mode_switch-bg');
    [modeSwitchNav, modeSwitchBg].forEach(element => {
      if (element) {
        const targetStyles = {
          left: isDark ? '50%' : '0%',
          right: isDark ? '0%' : '50%',
        };
        if (typeof gsap !== "undefined" && animate && !element.hasAttribute('data-no-transition')) {
          gsap.to(element, {
            ...targetStyles,
            duration: colorModeDuration,
            ease: colorModeEase,
            onStart: () => {
              element.style.left = isDark ? '0%' : '50%';
              element.style.right = isDark ? '50%' : '0%';
            },
            onComplete: () => {
              Object.assign(element.style, targetStyles);
            }
          });
        } else {
          Object.assign(element.style, targetStyles);
        }
        element.style.position = 'absolute';
        element.style.top = '0%';
        element.style.bottom = '0%';
      }
    });

    // Swap images based on mode
    swapImages(isDark);
    // Swap background images based on mode
    swapBackgroundImages(isDark);
    // Update logo appearance based on mode
	setCSLogos(isDark);
  }

  function setDarkMode(isDark, animate = true) {
    localStorage.setItem("dark-mode", isDark);
    htmlElement.classList.toggle("dark-mode", isDark);
    setColors(isDark, animate);
    setCSLogos(isDark);
    if (toggleEl) {
      toggleEl.forEach(element => {
        element.setAttribute("aria-pressed", isDark);
      });
    }
  }

  function initializeToggle() {
    const prefersDark = window.matchMedia("(prefers-color-scheme: dark)");
    const storedPreference = localStorage.getItem("dark-mode");
    let isDark;
    if (storedPreference !== null) {
      isDark = storedPreference === "true";
    } else {
      isDark = prefersDark.matches;
    }
    setDarkMode(isDark, false);
    setCSLogos(isDark);
    prefersDark.addEventListener("change", (e) => {
      if (localStorage.getItem("dark-mode") === null) {
        setDarkMode(e.matches);
      }
    });
  }

  window.addEventListener("DOMContentLoaded", () => {
    toggleEl = document.querySelectorAll("[tr-color-toggle]");
    toggleEl.forEach(element => {
      element.setAttribute("aria-label", "Toggle Dark Mode");
      element.setAttribute("role", "button");
      element.addEventListener("click", () => {
        const isDark = !htmlElement.classList.contains("dark-mode");
        setDarkMode(isDark);
      });
    });
    initializeToggle();
  });
}

colorModeToggle();
</script>

<script>
const API_URL = "https://api.github.com/repos";
const getStarGazers = async (repo) => {
  try {
    const response = await fetch(`${API_URL}/${repo}`);
    if (!response.ok) {
      throw new Error(`HTTP error! status: ${response.status}`);
    }
    const data = await response.json();
    return data.stargazers_count;
  } catch (error) {
    console.error("Error fetching data:", error);
    // Hide elements when there's an error
    document.querySelectorAll('.stargazers').forEach(element => {
      element.style.display = 'none';
    });
  }
};

getStarGazers('cpacker/MemGPT').then(stargazers => {
  if (stargazers) { // Only update if we have valid data
    const formatted = Intl.NumberFormat('en-US', {
      notation: "compact",
      maximumFractionDigits: 1
    }).format(stargazers);
    
    document.querySelectorAll('.stargazers').forEach(element => {
      element.textContent = formatted;
    });
  }
}).catch(error => {
  // Hide elements if the promise is rejected
  document.querySelectorAll('.stargazers').forEach(element => {
    element.style.display = 'none';
  });
});

</script>

<script>
// Close mobile menu on anchor click
if($(window).width() < 992){
     $('.navbar_component-solid').on('click', 'a', function() {
   $('.nav_menu-button').triggerHandler('tap');
 });
}
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  
  // 1. CTA Click tracking
  document.querySelectorAll('[plausible-event-name="CTA Click"]').forEach(function(button) {
    button.addEventListener('click', function(e) {
      var buttonName = this.getAttribute('data-button-name') || this.textContent.trim() || 'Unknown';
      
      if (typeof plausible !== 'undefined') {
        plausible('CTA Click', {props: {btn_name: buttonName}});
        console.log('✅ CTA Click sent:', buttonName);
      }
    });
  });
  
  // 2. Scroll depth tracking
  var scrollDepths = [25, 50, 75, 100];
  var triggered = {};
  
  window.addEventListener('scroll', function() {
    var scrollPercent = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
    
    scrollDepths.forEach(function(depth) {
      if (scrollPercent >= depth && !triggered[depth]) {
        if (typeof plausible !== 'undefined') {
          plausible('Scroll Depth', {props: {depth: depth + '%'}});
        }
        triggered[depth] = true;
      }
    });
  });
  
  // 3. Engaged 30s
  var engaged = false;
  setTimeout(function() {
    if (!engaged && typeof plausible !== 'undefined') {
      plausible('Engaged 30s');
      engaged = true;
    }
  }, 30000);
  
  // 4. Webflow native form tracking
  document.querySelectorAll('form').forEach(function(form) {
    form.addEventListener('submit', function(e) {
      var formName = this.getAttribute('data-name') || this.getAttribute('name') || 'Form';
      
      if (typeof plausible !== 'undefined') {
        plausible('Form Submit', {
          props: {
            form_name: formName,
            page: window.location.pathname
          }
        });
        console.log('✅ Form tracked:', formName);
      }
    });
  });
});

// 5. HubSpot form tracking
window.addEventListener('message', function(event) {
  if (event.data.type === 'hsFormCallback' && event.data.eventName === 'onFormSubmitted') {
    var formId = event.data.id;
    
    if (typeof plausible !== 'undefined') {
      plausible('HubSpot Form Submit', {
        props: {
          form_id: formId,
          page: window.location.pathname
        }
      });
      console.log('✅ HubSpot Form tracked:', formId);
    }
  }
});
</script></body></html>